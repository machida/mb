<div>
  <div class="mb-8">
    <h1 class="a--heading is--xxl mb-2 spec--archive-year-title"><%= @year %>年の記事</h1>
    <p class="text-gray-500"><%= @articles.count %>件の記事があります</p>
  </div>

  <!-- 月別ナビゲーション -->
  <div class="mb-12">
    <h2 class="a--heading is--lg mb-4">月別アーカイブ</h2>
    <ul class="flex flex-wrap gap-x-6 gap-y-2">
      <% (1..12).each do |month| %>
        <% count = @monthly_counts[format("%02d", month)] || 0 %>
        <li>
          <% if count > 0 %>
            <%= link_to "#{month}月 (#{count})", archive_month_path(@year, month),
                  class: "text-link hover-text-link" %>
          <% else %>
            <span class="text-muted"><%= month %>月 (0)</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <!-- 記事一覧 -->
  <div class="l--articles">
    <%= render partial: "article_item", collection: @articles %>
  </div>

  <% if @articles.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg"><%= @year %>年の記事はまだありません</p>
    </div>
  <% end %>

  <!-- Pagination -->
  <div class="mt-8 flex justify-center spec--pagination">
    <%= paginate @articles %>
  </div>

  <!-- ナビゲーション -->
  <div class="mt-8 text-center">
    <%= link_to "← トップページに戻る", root_path, class: "text-link hover-text-link" %>
  </div>
</div>

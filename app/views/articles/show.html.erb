<% content_for :head do %>
  <% if @article.draft? %>
    <meta name="robots" content="noindex, nofollow">
  <% end %>
  <% if @article.summary.present? %>
    <meta name="description" content="<%= @article.summary %>">
    <meta property="og:description" content="<%= @article.summary %>">
  <% end %>
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:type" content="article">
  <meta property="og:title" content="<%= @article.title %>">
  <meta property="og:site_name" content="<%= SiteSetting.site_title %>">
  <% og_image_url = @article.og_image_url %>
  <% if og_image_url.present? %>
    <meta property="og:image" content="<%= og_image_url %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  <% end %>
<% end %>

<article class="prose prose-lg max-w-none">
  <header class="l--article-header">
    <h1 class="a--heading is--xxxl spec--article-title"><%= @article.title %></h1>
    <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
      <% if show_author_info? %>
        <span class="spec--article-author">著者: <%= @article.author %></span>
      <% end %>
      <time datetime="<%= @article.created_at.iso8601 %>">
        <%= link_to archive_month_path(@article.created_at.year, @article.created_at.month), class: "text-gray-500 hover:text-gray-700 hover:underline spec--article-date" do %>
          <%= format_date_with_weekday(@article.created_at) %>
        <% end %>
      </time>
    </div>
  </header>

  <% if @article.draft? %>
    <div class="a--card is--warning spec--draft-notice mb-6">
      <h2 class="flex items-center gap-1 text-lg font-semibold mb-2">
        <span class="material-symbols-outlined text-amber-600" style="font-size: 1.25rem;">warning</span>
        この記事は下書きです
      </h2>
      <p class="text-sm">この記事は現在下書き状態で、一般には公開されていません。</p>
    </div>
  <% end %>

  <div class="a--prose spec--article-content py-12">
    <%= markdown(@article.body) %>
  </div>
</article>

<nav class="mt-8 pt-4 border-t border-gray-200">
  <div class="flex items-center justify-between gap-4">
    <div class="flex-1">
      <% if @prev_article %>
        <%= link_to article_path(@prev_article), class: "group flex flex-col gap-1 text-sm text-gray-500 hover:text-gray-800 spec--prev-article-link" do %>
          <span class="flex items-center gap-1">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            前の記事
          </span>
          <span class="line-clamp-1 group-hover:underline"><%= @prev_article.title %></span>
        <% end %>
      <% end %>
    </div>
    <div class="flex-none">
      <%= link_to "記事一覧", root_path, class: "a--button is--md is--mono" %>
    </div>
    <div class="flex-1 text-right">
      <% if @next_article %>
        <%= link_to article_path(@next_article), class: "group flex flex-col items-end gap-1 text-sm text-gray-500 hover:text-gray-800 spec--next-article-link" do %>
          <span class="flex items-center gap-1">
            次の記事
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          </span>
          <span class="line-clamp-1 group-hover:underline"><%= @next_article.title %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>

<% if current_user_signed_in? %>
  <div class="mt-8 flex justify-end gap-2">
    <%= link_to "編集", edit_admin_article_path(@article), class: "a--button is--md is--secondary" %>
    <%= link_to "削除", admin_article_path(@article), method: :delete,
                data: { confirm: "この記事を削除しますか？削除すると元に戻せません。" },
                class: "a--button is--md is--border-danger spec--delete-article-button" %>
  </div>
<% end %>

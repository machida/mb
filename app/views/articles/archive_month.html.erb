<div>
  <div class="mb-8">
    <h1 class="a--heading is--xxl mb-2 spec--archive-month-title"><%= @year %>年<%= @month %>月の記事</h1>
    <p class="text-gray-500"><%= @articles.count %>件の記事があります</p>
  </div>

  <!-- ナビゲーション -->
  <nav class="mb-12 flex justify-center gap-8 items-baseline">
    <% if @month > 1 %>
      <%= link_to "← #{@month - 1}月", archive_month_path(@year, @month - 1),
            class: "text-link hover-text-link" %>
    <% end %>

    <%= link_to "#{@year}年の一覧", archive_year_path(@year),
          class: "text-link hover-text-link" %>

    <% if @month < 12 %>
      <%= link_to "#{@month + 1}月 →", archive_month_path(@year, @month + 1),
            class: "text-link hover-text-link" %>
    <% end %>
  </nav>

  <!-- 記事一覧 -->
  <div class="l--articles">
    <%= render partial: "article_item", collection: @articles %>
  </div>

  <% if @articles.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg"><%= @year %>年<%= @month %>月の記事はまだありません</p>
    </div>
  <% end %>

  <!-- Pagination -->
  <div class="mt-8 flex justify-center spec--pagination">
    <%= paginate @articles %>
  </div>

  <!-- ナビゲーション -->
  <div class="mt-8 text-center">
    <%= link_to "← トップページに戻る", root_path, class: "text-link hover-text-link" %>
  </div>
</div>
